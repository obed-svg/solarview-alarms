# Plantilla de .env — copiar a .env y llenar los valores reales.
# .env NUNCA se commitea; esta plantilla no contiene secretos.

# Host de la API SolarView, SIN esquema (el cliente antepone https://)
SOLARSOLARVIEW_BASE_URL=

# Token estático de la API SolarView (se envía como "Authorization: Token <valor>")
static_token=

# URL del webhook de Discord para notificaciones
webhook_discord=
